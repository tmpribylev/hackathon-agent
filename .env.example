ANTHROPIC_API_KEY=your-api-key-here
ANTHROPIC_BASE_URL="https://litellm.secondstack.t1a.io"

# Google Sheets
SPREADSHEET_ID=your-spreadsheet-id

# Notion internal integration (https://www.notion.so/my-integrations)
NOTION_TOKEN=your-notion-internal-integration-token
NOTION_ACTION_ITEMS_DB_ID=your-notion-database-id
NOTION_SENDER_DB_ID=your-sender-database-id
NOTION_EMAILS_DB_ID=your-notion-emails-database-id

# Telegram bot (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# LLM input sanitisation — pipe-separated list of strings to strip before
# sending any text to the Anthropic API (e.g. content that triggers API errors).
# Example: LLM_BLOCKED_STRINGS="string that breaks api|another bad string"
LLM_BLOCKED_STRINGS=
